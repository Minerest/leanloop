# Local playground / scratch (not part of the tool itself).
# Ignore everything in playground/ except the bundled demo, which ships with
# the repo. (`playground/*` instead of `playground/` so the re-include below
# can take effect — git won't re-include paths inside an excluded directory.)
playground/*
!playground/demo/
playground/demo/__pycache__/
playground/demo/*.bak

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Virtualenvs
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# Loop_fix runtime
/tmp/llama-server-*.log
